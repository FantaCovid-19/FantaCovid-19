{
  "env": {
    "browser": true,
    "es2021": true
  },
  "plugins": ["react", "import", "prefer-object-spread"],
  "settings": {
    "react": {
      "version": "detect"
    }
  },
  "globals": {
    "process": false,
    "Promise": true,
    "window": true,
    "$": true,
    "ga": true,
    "jQuery": true,
    "router": true
  },
  "rules": {
    "indent": ["error", 2],
    "linebreak-style": ["error", "unix"],
    "quotes": ["error", "single"],
    "semi": ["error", "never"],
    "react/jsx-uses-vars": ["error"],
    "import/named": 2,
    "import/no-named-as-default": 0,
    "import/no-named-as-default-member": 0,
    "import/order": 2,
    "react/prop-types": "off"
  },
  "extends": [
    "standard",
    "plugin:react/recommended",
    "plugin:react-hooks/recommended",
    "plugin:react/jsx-runtime",
    "plugin:import/recommended",
    "plugin:import/typescript",
    "eslint-config-prettier",
    "prettier"
  ],
  "parserOptions": {
    "ecmaFeatures": {
      "experimentalObjectRestSpread": true,
      "jsx": true
    },
    "sourceType": "module"
  }
}
