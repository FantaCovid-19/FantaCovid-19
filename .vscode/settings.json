{
  "search.showLineNumbers": true,
  "search.collapseResults": "auto",
  "search.followSymlinks": false,
  "search.quickOpen.includeSymbols": false,
  "search.smartCase": true,
  "search.exclude": {
    "**/node_modules": true,
    "**/bower_components": true,
    "**/.git": true
  },

  "window.zoomLevel": 0,
  "window.newWindowDimensions": "maximized",
  "window.restoreFullscreen": true,
  "window.restoreWindows": "all",
  "window.title": "${rootName}${separator}${appName}",

  "extensions.autoUpdate": true,
  "extensions.ignoreRecommendations": true,

  "editor.cursorStyle": "line",
  "editor.tabSize": 2,
  "editor.fontSize": 14,
  "editor.wordWrap": "on",
  "editor.formatOnSave": true,
  "editor.formatOnPaste": true,
  "editor.insertSpaces": true,
  "editor.minimap.enabled": false,
  "editor.defaultFormatter": "esbenp.prettier-vscode",
  "editor.renderWhitespace": "boundary",
  "editor.detectIndentation": false,
  "editor.multiCursorModifier": "alt",
  "editor.suggest.showStatusBar": true,
  "editor.renderControlCharacters": false,

  "files.encoding": "utf8",
  "files.trimTrailingWhitespace": true,
  "files.trimFinalNewlines": true,
  "files.insertFinalNewline": true,
  "files.simpleDialog.enable": true,
  "files.associations": {
    "*.js": "javascript",
    "*jsx": "javascriptreact"
  },
  "files.watcherExclude": {
    "**/.git/objects/**": true,
    "**/.git/subtree-cache/**": true,
    "**/node_modules/*/**": true
  },
  "files.exclude": {
    "**/.git": true,
    "**/.DS_Store": true,
    "**/.hg": true,
    "**/.svn": true,
    "jspm_packagesb": true,
    "node_modules": true
  },

  "terminal.integrated.defaultProfile.windows": "PowerShell",
  "terminal.integrated.minimumContrastRatio": 3,

  "workbench.colorTheme": "Material Theme Palenight",
  "workbench.iconTheme": "material-icon-theme",
  "workbench.commandPalette.preserveInput": true,
  "workbench.editor.closeOnFileDelete": true,

  "javascript.updateImportsOnFileMove.enabled": "always",
  "javascript.preferences.quoteStyle": "single",
  "javascript.preferences.importModuleSpecifier": "relative",
  "javascript.preferences.importModuleSpecifierEnding": "minimal",
  "javascript.referencesCodeLens.enabled": true,
  "javascript.referencesCodeLens.showOnAllFunctions": true,
  "javascript.suggest.completeFunctionCalls": true,

  "git.allowForcePush": true,
  "git.allowNoVerifyCommit": true,
  "git.autofetch": true,
  "git.confirmSync": true,
  "git.fetchOnPull": true,
  "git.inputValidationSubjectLength": 72,
  "git.suggestSmartCommit": true,

  "emmet.showAbbreviationSuggestions": true,
  "emmet.showSuggestionsAsSnippets": true,
  "emmet.includeLanguages": {
    "javascript": "javascriptreact",
    "jsx-sublime-babel-tags": "javascriptreact",
    "tsx": "typescriptreact"
  },

  "eslint.run": "onSave",
  "eslint.packageManager": "npm",
  "eslint.alwaysShowStatus": true,
  "eslint.lintTask.enable": true,

  "errorLens.messageTemplate": "($source) $message",
  "errorLens.removeLinebreaks": true,
  "errorLens.enabledDiagnosticLevels": ["warning", "error", "hint"],

  "prettier.ignorePath": ".prettierignore",
  "prettier.semi": false,
  "prettier.singleQuote": true,
  "prettier.jsxSingleQuote": true,

  "material-icon-theme.activeIconPack": "react_redux",

  "npm.packageManager": "npm",

  "security.workspace.trust.enabled": false,

  "[markdown]": {
    "editor.formatOnSave": true,
    "editor.renderWhitespace": "boundary",
    "editor.acceptSuggestionOnEnter": "off"
  }
}
